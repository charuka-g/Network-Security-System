# MongoDB — leave blank to use local data/phisingData.csv instead
MONGO_DB_URL
MONGO_DB_DATABASE
MONGO_DB_COLLECTION

# MLflow / DagsHub — leave blank to skip tracking
MLFLOW_TRACKING_URI
MLFLOW_TRACKING_USERNAME
MLFLOW_TRACKING_PASSWORD
DAGSHUB_REPO_OWNER
DAGSHUB_REPO_NAME

# AWS — required for S3 artifact sync and deployment
AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY
AWS_REGION
